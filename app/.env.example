# 경기기후플랫폼 API 설정
CLIMATE_API_KEY=your_api_key_here
CLIMATE_API_BASE_URL=https://climate.gg.go.kr/ols/data/api

# WMS API 설정 (클라이언트에서 사용)
NEXT_PUBLIC_CLIMATE_API_KEY=your_api_key_here

# WMS 레이어 이름 (선택사항 - 경기기후플랫폼 API 문서 참조)
# NEXT_PUBLIC_WMS_LAYER_HEAT_RISK=spggcee:layer_name
# NEXT_PUBLIC_WMS_LAYER_FLOOD_RISK=spggcee:layer_name
# NEXT_PUBLIC_WMS_LAYER_THERMAL=spggcee:layer_name
# NEXT_PUBLIC_WMS_LAYER_UTCI=spggcee:layer_name
# NEXT_PUBLIC_WMS_LAYER_FLOOD_TRACE=spggcee:layer_name
# NEXT_PUBLIC_WMS_LAYER_EXTREME_RAIN=spggcee:layer_name
# NEXT_PUBLIC_WMS_LAYER_GREEN=spggcee:layer_name
# NEXT_PUBLIC_WMS_LAYER_SHELTER=spggcee:layer_name
# NEXT_PUBLIC_WMS_LAYER_FLOOD_DEFENSE=spggcee:layer_name

